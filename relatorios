<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Relatórios Completos - Estúdio Rafaela Lisboa</title>

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Ícones -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Bibliotecas para exportação -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <!-- Supabase -->
    <script src="https://unpkg.com/@supabase/supabase-js@2"></script>

    <style>
      /* ===== CSS ORIGINAL (MANTIDO) ===== */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --verde-principal: #3a6b5c;
        --verde-claro: #8fc1b0;
        --verde-pastel: #d4ede4;
        --grafite: #2c2c2c;
        --grafite-claro: #4a4a4a;
        --off-white: #faf9f6;
        --branco: #ffffff;

        --vermelho-urgente: #e74c3c;
        --vermelho-suave: #ffe5e5;
        --laranja-atencao: #f39c12;
        --laranja-suave: #fff3cd;
        --roxo-celebracao: #9b59b6;
        --roxo-suave: #f3e5f5;
        --verde-sucesso: #27ae60;
        --azul-info: #3498db;
        --azul-suave: #e3f2fd;

        --pago: #27ae60;
        --pendente: #f39c12;
        --atrasado: #e74c3c;

        --font-titulos: "Cormorant Garamond", serif;
        --font-corpo: "Montserrat", sans-serif;

        --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
        --shadow-hover: 0 8px 24px rgba(58, 107, 92, 0.15);

        --card-padding: 20px;
        --grid-gap: 20px;
      }

      html {
        font-size: 14px;
      }

      body {
        font-family: var(--font-corpo);
        background: var(--off-white);
        color: var(--grafite);
        min-height: 100vh;
      }

      /* ===== HEADER ===== */
      .header {
        background: var(--branco);
        box-shadow: var(--shadow);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .header-content {
        max-width: 1600px;
        margin: 0 auto;
        padding: 0.8rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo-area {
        display: flex;
        align-items: center;
        gap: 0.8rem;
      }

      .logo-icon {
        width: 40px;
        height: 40px;
        background: var(--verde-principal);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
      }

      .logo-icon i {
        font-size: 1.5rem;
        color: var(--branco);
      }

      .logo-text h1 {
        font-family: var(--font-titulos);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--grafite);
        line-height: 1.2;
      }

      .logo-text span {
        font-size: 0.7rem;
        color: var(--verde-principal);
      }

      .user-area {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        position: relative;
      }

      .user-info {
        text-align: right;
      }

      .user-name {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--grafite);
      }

      .user-role {
        font-size: 0.7rem;
        color: var(--verde-principal);
      }

      .user-avatar {
        width: 38px;
        height: 38px;
        background: var(--verde-pastel);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--verde-principal);
        font-weight: 600;
        font-size: 0.95rem;
      }

      .btn-icon {
        width: 35px;
        height: 35px;
        border: none;
        border-radius: 8px;
        background: var(--off-white);
        color: var(--grafite);
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
      }

      .btn-icon:hover {
        background: var(--verde-pastel);
        color: var(--verde-principal);
      }

      /* ===== MENU FAVORITOS ===== */
      .favorites-dropdown {
        position: relative;
        display: inline-block;
      }

      .favorites-dropdown-content {
        display: none;
        position: absolute;
        right: 0;
        top: 40px;
        background-color: var(--branco);
        min-width: 220px;
        box-shadow: var(--shadow-hover);
        border-radius: 12px;
        padding: 0.5rem 0;
        z-index: 200;
      }

      .favorites-dropdown:hover .favorites-dropdown-content {
        display: block;
      }

      .favorites-dropdown-content a {
        color: var(--grafite);
        padding: 0.6rem 1rem;
        text-decoration: none;
        display: block;
        font-size: 0.85rem;
        transition: background 0.2s;
      }

      .favorites-dropdown-content a:hover {
        background: var(--verde-pastel);
        color: var(--verde-principal);
      }

      .favorites-dropdown-content .empty-favorites {
        padding: 0.6rem 1rem;
        color: var(--grafite-claro);
        font-style: italic;
        text-align: center;
      }

      /* ===== CONTEÚDO PRINCIPAL ===== */
      .main-content {
        max-width: 1600px;
        margin: 0 auto;
        padding: 1.5rem;
      }

      .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .page-header h1 {
        font-family: var(--font-titulos);
        font-size: 2rem;
        font-weight: 600;
        color: var(--grafite);
        margin-bottom: 0.2rem;
      }

      .page-header .subtitle {
        color: var(--verde-principal);
        font-size: 0.9rem;
      }

      /* ===== BOTÕES ===== */
      .btn-primary {
        background: var(--verde-sucesso);
        color: var(--branco);
        border: none;
        padding: 0.6rem 1.5rem;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.3s;
        text-decoration: none;
      }

      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-hover);
      }

      .btn-secondary {
        background: #95a5a6;
        color: var(--branco);
        border: none;
        padding: 0.5rem 1.2rem;
        border-radius: 30px;
        font-size: 0.85rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.3s;
      }

      .btn-secondary:hover {
        background: #7f8c8d;
      }

      .btn-outline {
        background: none;
        border: 1px solid var(--verde-principal);
        color: var(--verde-principal);
        padding: 0.5rem 1.2rem;
        border-radius: 30px;
        font-size: 0.85rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.3s;
      }

      .btn-outline:hover {
        background: var(--verde-principal);
        color: var(--branco);
      }

      .btn-success {
        background: var(--verde-sucesso);
        color: var(--branco);
        border: none;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.3s;
      }

      .btn-success:hover {
        filter: brightness(1.1);
      }

      /* ===== FILTROS ===== */
      .filters-bar {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: var(--branco);
        border-radius: 12px;
        box-shadow: var(--shadow);
      }

      .periodo-group {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .periodo-btn {
        padding: 0.4rem 1rem;
        border: 1px solid var(--verde-claro);
        background: var(--branco);
        border-radius: 30px;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.3s;
      }

      .periodo-btn:hover {
        background: var(--verde-pastel);
      }

      .periodo-btn.active {
        background: var(--verde-principal);
        color: var(--branco);
        border-color: var(--verde-principal);
      }

      .date-range {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .date-range input {
        padding: 0.4rem 0.8rem;
        border: 1px solid var(--verde-claro);
        border-radius: 6px;
        font-size: 0.8rem;
      }

      .filter-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-left: auto;
      }

      .filter-group label {
        font-size: 0.8rem;
        color: var(--verde-principal);
      }

      .filter-select {
        padding: 0.4rem 0.8rem;
        border: 1px solid var(--verde-claro);
        border-radius: 30px;
        font-size: 0.8rem;
        background: var(--branco);
        min-width: 140px;
      }

      /* ===== TABS PRINCIPAIS ===== */
      .tabs-principais {
        display: flex;
        gap: 0.3rem;
        border-bottom: 1px solid var(--verde-pastel);
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        overflow-x: auto;
      }

      .tab-principal {
        padding: 0.6rem 1.2rem;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.9rem;
        color: var(--grafite);
        opacity: 0.7;
        border-bottom: 2px solid transparent;
        transition: all 0.3s;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
      }

      .tab-principal:hover {
        opacity: 1;
        color: var(--verde-principal);
      }

      .tab-principal.active {
        opacity: 1;
        color: var(--verde-principal);
        border-bottom-color: var(--verde-principal);
        font-weight: 600;
      }

      /* ===== SUBTABS ===== */
      .sub-tabs {
        display: flex;
        gap: 0.3rem;
        margin-bottom: 1.2rem;
        flex-wrap: wrap;
        background: var(--branco);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        box-shadow: var(--shadow);
        overflow-x: auto;
      }

      .sub-tab {
        padding: 0.4rem 1rem;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.8rem;
        color: var(--grafite-claro);
        border-radius: 20px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        white-space: nowrap;
      }

      .sub-tab:hover {
        background: var(--verde-pastel);
        color: var(--verde-principal);
      }

      .sub-tab.active {
        background: var(--verde-principal);
        color: var(--branco);
      }

      /* ===== CARDS DE RESUMO ===== */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--grid-gap);
        margin-bottom: 1.5rem;
      }

      .stat-card {
        background: var(--branco);
        padding: 1.2rem;
        border-radius: 16px;
        box-shadow: var(--shadow);
        display: flex;
        align-items: center;
        gap: 0.8rem;
        transition: all 0.3s;
        position: relative;
        cursor: help;
      }

      .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-hover);
      }

      .stat-card:hover::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: var(--grafite);
        color: var(--branco);
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        font-size: 0.7rem;
        white-space: nowrap;
        z-index: 10;
        margin-bottom: 0.5rem;
        box-shadow: var(--shadow);
      }

      .stat-icon {
        width: 48px;
        height: 48px;
        background: var(--verde-pastel);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .stat-icon i {
        font-size: 1.5rem;
        color: var(--verde-principal);
      }

      .stat-icon.orange {
        background: var(--laranja-suave);
      }
      .stat-icon.orange i {
        color: var(--laranja-atencao);
      }
      .stat-icon.red {
        background: var(--vermelho-suave);
      }
      .stat-icon.red i {
        color: var(--vermelho-urgente);
      }
      .stat-icon.purple {
        background: var(--roxo-suave);
      }
      .stat-icon.purple i {
        color: var(--roxo-celebracao);
      }

      .stat-info {
        flex: 1;
        min-width: 0;
      }

      .stat-value {
        font-family: var(--font-titulos);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--grafite);
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .stat-label {
        color: var(--verde-principal);
        font-size: 0.8rem;
        font-weight: 500;
      }

      .stat-trend {
        font-size: 0.7rem;
        margin-top: 0.2rem;
        color: var(--grafite-claro);
      }

      .trend-up {
        color: var(--verde-sucesso);
      }

      .trend-down {
        color: var(--vermelho-urgente);
      }

      /* ===== GRÁFICOS ===== */
      .charts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--grid-gap);
        margin-bottom: 1.5rem;
      }

      .chart-card {
        background: var(--branco);
        border-radius: 16px;
        padding: 1.2rem;
        box-shadow: var(--shadow);
      }

      .chart-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
      }

      .chart-title {
        font-family: var(--font-titulos);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--grafite);
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }

      .chart-container {
        height: 250px;
        position: relative;
      }

      /* ===== TABELAS DE RELATÓRIOS ===== */
      .report-container {
        background: var(--branco);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: var(--shadow);
        margin-bottom: 1.5rem;
      }

      .report-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .report-title {
        font-family: var(--font-titulos);
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--grafite);
      }

      .report-actions {
        display: flex;
        gap: 0.5rem;
      }

      .report-summary {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: var(--off-white);
        border-radius: 12px;
      }

      .summary-item {
        text-align: center;
        min-width: 120px;
      }

      .summary-value {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--verde-principal);
        line-height: 1.2;
      }

      .summary-label {
        font-size: 0.75rem;
        color: var(--grafite-claro);
      }

      .table-responsive {
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }

      th {
        text-align: left;
        padding: 0.8rem 0.5rem;
        color: var(--verde-principal);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        border-bottom: 2px solid var(--verde-pastel);
      }

      td {
        padding: 0.8rem 0.5rem;
        border-bottom: 1px solid var(--verde-pastel);
        cursor: pointer;
      }

      tr:hover td {
        background: rgba(58, 107, 92, 0.02);
      }

      /* Destaques especiais */
      .destaque-aniversario {
        background-color: var(--roxo-suave);
        font-weight: 600;
      }
      .destaque-vencido {
        background-color: var(--vermelho-suave);
        color: var(--vermelho-urgente);
        font-weight: 600;
      }
      .destaque-atencao {
        background-color: var(--laranja-suave);
        color: var(--laranja-atencao);
        font-weight: 600;
      }

      .foto-aluno {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        background: var(--verde-pastel);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--verde-principal);
        font-size: 1.2rem;
      }

      .status-badge {
        display: inline-block;
        padding: 0.2rem 0.8rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
        color: var(--branco);
      }

      .status-badge.pago,
      .status-badge.recebido,
      .status-badge.presente {
        background: var(--pago);
      }
      .status-badge.pendente {
        background: var(--pendente);
      }
      .status-badge.atrasado,
      .status-badge.ausente {
        background: var(--atrasado);
      }

      .badge {
        display: inline-block;
        padding: 0.15rem 0.5rem;
        border-radius: 20px;
        font-size: 0.65rem;
        font-weight: 500;
      }

      .badge.verde {
        background: var(--verde-pastel);
        color: var(--verde-principal);
      }

      .badge.orange {
        background: var(--laranja-suave);
        color: var(--laranja-atencao);
      }

      .badge.red {
        background: var(--vermelho-suave);
        color: var(--vermelho-urgente);
      }

      .badge.purple {
        background: var(--roxo-suave);
        color: var(--roxo-celebracao);
      }

      /* ===== PROGRESS BAR ===== */
      .progress-bar {
        width: 100%;
        height: 6px;
        background: var(--verde-pastel);
        border-radius: 3px;
        overflow: hidden;
      }

      .progress-fill {
        height: 100%;
        background: var(--verde-principal);
        border-radius: 3px;
        transition: width 0.3s ease;
      }

      /* ===== ALERTA INTELIGENTE ===== */
      .alert-banner {
        background: var(--vermelho-suave);
        border-left: 4px solid var(--vermelho-urgente);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .alert-banner i {
        font-size: 1.5rem;
        color: var(--vermelho-urgente);
      }
      .alert-banner .alert-content {
        flex: 1;
      }
      .alert-banner .alert-title {
        font-weight: 600;
        margin-bottom: 0.2rem;
      }
      .alert-banner .alert-message {
        font-size: 0.9rem;
      }
      .alert-banner .alert-close {
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        color: var(--grafite-claro);
      }

      /* ===== MODAL ===== */
      .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 2000;
        align-items: center;
        justify-content: center;
      }
      .modal.show {
        display: flex;
      }
      .modal-content {
        background: var(--branco);
        border-radius: 16px;
        max-width: 600px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        padding: 2rem;
        position: relative;
      }
      .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--grafite-claro);
      }

      /* ===== FAVORITOS ===== */
      .favorite-star {
        color: #f1c40f;
        cursor: pointer;
        margin-left: 0.5rem;
      }
      .favorite-star.far {
        color: var(--grafite-claro);
      }

      /* ===== PAGINAÇÃO ===== */
      .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
      }
      .pagination-btn {
        background: var(--branco);
        border: 1px solid var(--verde-claro);
        color: var(--grafite);
        padding: 0.4rem 1rem;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 0.85rem;
      }
      .pagination-btn:hover:not(:disabled) {
        background: var(--verde-pastel);
        color: var(--verde-principal);
      }
      .pagination-btn:disabled {
